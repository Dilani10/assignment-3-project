# Shopping Optimiser - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# ===========================================

# Supabase PostgreSQL Connection String
# Replace [PROJECT-ID] with your Supabase project ID
# Replace [YOUR-PASSWORD] with your database password
# If password contains special characters (@, :, /, ?, #, %, [, ]), URL-encode them
DATABASE_URL=postgresql://postgres.[PROJECT-ID]:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# Supabase Configuration
SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_ANON_KEY=[YOUR-SUPABASE-ANON-KEY]

# ===========================================
# FRONTEND ENVIRONMENT VARIABLES
# ===========================================

# API URL for backend connection
# For local development: http://localhost:8000
# For production: https://your-backend-domain.vercel.app
VITE_API_URL=http://localhost:8000