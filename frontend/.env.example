# API URL for backend connection
# For local development: http://localhost:8000
# For production: https://your-backend-domain.vercel.app
VITE_API_URL=http://localhost:8000

# Google Maps API Key for Places Autocomplete
# Get your API key from: https://console.cloud.google.com/google/maps-apis/
# Required APIs: Places API, Maps JavaScript API
# Restrict your API key to your domain for security
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
